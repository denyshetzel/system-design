POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_strong_postgres_password
POSTGRES_DB=shortering-db

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=your_strong_pgadmin_password
PGADMIN_PORT=5050

APP_BASE_URL=http://localhost:8080
DATASOURCE_URL=jdbc:postgresql://postgresdb:5432/shortering-db
SERVER_ERROR_INCLUDE_MESSAGE=never
SERVER_ERROR_INCLUDE_STACKTRACE=never
SPRINGDOCS_ENABLED=false

WORKER_ID_API=1
WORKER_ID_API_NATIVE=2

K6_RATE=30
K6_DURATION=2m
K6_PRE_ALLOCATED_VUS=20
K6_MAX_VUS=200
K6_P95_MS=400
K6_P99_MS=800
K6_ERROR_RATE=0.01
